generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id                 String  @id @default("site-settings")
  heroTitle          String  @default("Ayomide Dolapo")
  heroSubtitle       String  @default("Fullstack Developer & Digital Creator")
  heroDescription    String? @db.Text
  aboutContent       String? @db.Text
  availabilityStatus String  @default("open")
  resumeUrl          String?
  contactEmail       String?
  phoneNumber        String?
  whatsappNumber     String  @default("2348079460647")
  seoTitle           String?
  seoDescription     String?
  ogImage            String?
  socialLinks        Json?
  updatedAt          DateTime @updatedAt
}

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  projects    Project[]
  blogPosts   BlogPost[]
  createdAt   DateTime   @default(now())
}

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  subtitle    String?
  description String?  @db.Text
  problem     String?  @db.Text
  process     String?  @db.Text
  solution    String?  @db.Text
  results     String?  @db.Text
  thumbnail   String?
  gallery     String[]
  videoUrl    String?
  blogUrl     String?
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  tags        String[]
  featured    Boolean  @default(false)
  status      String   @default("draft")
  order       Int      @default(0)
  liveUrl     String?
  repoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  testimonials Testimonial[]
  @@index([slug])
  @@index([featured, status])
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String?
  content     String   @db.Text
  coverImage  String?
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  tags        String[]
  status      String   @default("draft")
  publishedAt DateTime?
  readingTime Int?
  ogImage     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([status, publishedAt])
}

model Service {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?  @db.Text
  icon        String?
  features    String[]
  priceInfo   String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Skill {
  id          String @id @default(cuid())
  name        String
  category    String
  proficiency Int?
  icon        String?
  order       Int    @default(0)
}

model Experience {
  id           String   @id @default(cuid())
  company      String
  role         String
  type         String   @default("fulltime")
  location     String?
  startDate    DateTime
  endDate      DateTime?
  isCurrent    Boolean  @default(false)
  description  String?  @db.Text
  achievements String[]
  companyUrl   String?
  logo         String?
  order        Int      @default(0)
}

model Education {
  id          String   @id @default(cuid())
  institution String
  degree      String
  field       String?
  startDate   DateTime
  endDate     DateTime?
  isCurrent   Boolean  @default(false)
  description String?
  logo        String?
  order       Int      @default(0)
}

model Certification {
  id            String   @id @default(cuid())
  name          String
  issuer        String
  issueDate     DateTime
  expiryDate    DateTime?
  credentialUrl String?
  image         String?
  order         Int      @default(0)
}

model Testimonial {
  id         String   @id @default(cuid())
  clientName String
  clientRole String?
  company    String?
  content    String   @db.Text
  image      String?
  logo       String?
  rating     Int?
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id])
  isActive   Boolean  @default(true)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
}

model ContactSubmission {
  id              String   @id @default(cuid())
  name            String
  email           String
  phone           String?
  subject         String?
  message         String   @db.Text
  budget          String?
  serviceInterest String?
  source          String?
  read            Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([read, createdAt])
}

model MediaAsset {
  id        String   @id @default(cuid())
  publicId  String   @unique
  url       String
  secureUrl String
  type      String
  format    String?
  width     Int?
  height    Int?
  size      Int?
  tags      String[]
  createdAt DateTime @default(now())
}